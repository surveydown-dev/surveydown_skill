# Shared Dockerfile for every surveydown survey deployed to Hugging Face Spaces.
# It is identical across all Spaces; per-template R packages come from packages.txt
# (generated by deploy.sh from the template's library() calls).
FROM rocker/r-ver:4.5.2

# ---- System libraries: superset covering every template (incl. geospatial for sf/leaflet) ----
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates curl git gdebi-core \
      libcurl4-openssl-dev libssl-dev libxml2-dev \
      libfontconfig1-dev libfreetype6-dev libharfbuzz-dev libfribidi-dev \
      libpng-dev libtiff5-dev libjpeg-dev libgit2-dev \
      libgdal-dev libgeos-dev libproj-dev libudunits2-dev \
    && rm -rf /var/lib/apt/lists/*

# ---- Quarto CLI (pinned direct download; avoids GitHub API rate limits on build servers) ----
ARG QUARTO_VERSION=1.9.38
RUN curl -fsSL -o /tmp/quarto.deb \
      "https://github.com/quarto-dev/quarto-cli/releases/download/v${QUARTO_VERSION}/quarto-${QUARTO_VERSION}-linux-amd64.deb" \
    && gdebi --non-interactive /tmp/quarto.deb \
    && rm /tmp/quarto.deb

# ---- Posit Public Package Manager for fast precompiled R package binaries ----
RUN . /etc/os-release \
    && echo "options(repos = c(P3M = 'https://packagemanager.posit.co/cran/__linux__/$VERSION_CODENAME/latest'))" \
       >> /usr/local/lib/R/etc/Rprofile.site

# ---- surveydown (dev v1.3.0 from GitHub; CRAN only has 1.0.1) ----
RUN R -q -e "install.packages('pak')" \
    && R -q -e "pak::pak('surveydown-dev/surveydown')"

# ---- Per-template extra R packages (one per line in packages.txt; may be empty) ----
COPY packages.txt /tmp/packages.txt
RUN R -q -e "p <- readLines('/tmp/packages.txt'); p <- p[nzchar(trimws(p))]; if (length(p)) pak::pak(p)"

# ---- Hugging Face runs the container as uid 1000; create that user first ----
RUN useradd -m -u 1000 user
USER user
ENV HOME=/home/user \
    PATH=/home/user/.local/bin:$PATH
WORKDIR /home/user/app

# ---- App files, owned by the runtime user (surveydown writes _survey/ and preview_data.csv) ----
COPY --chown=user:user . /home/user/app

# ---- Launch the Shiny survey on the port Hugging Face proxies (7860) ----
EXPOSE 7860
CMD ["R", "-e", "options(shiny.port=7860, shiny.host='0.0.0.0'); shiny::runApp('/home/user/app', launch.browser=FALSE)"]
